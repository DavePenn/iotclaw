# IoTClaw 配置文件示例
# 复制为 iotclaw.toml 并修改

# 默认模型
model = "qwen-plus"

# 默认 Provider: dashscope, openai
provider = "dashscope"

# Skills 目录
skills_dir = "skills"

# 数据目录（日志、截图等）
data_dir = "data"

# 日志级别: debug, info, warn, error
log_level = "info"

# Agent Loop 最大迭代次数
max_iterations = 10

# Token 上限（上下文压缩阈值）
token_limit = 6000
