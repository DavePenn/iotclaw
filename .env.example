# DashScope (阿里云大模型)
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-turbo

# 飞书 Webhook (简单版)
FEISHU_WEBHOOK=
FEISHU_SERVER_PORT=3000

# 飞书 API (完整版 — 需要在飞书开放平台创建应用)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# 企业微信 Webhook (简单版)
WECHAT_WEBHOOK=

# 企业微信 API (完整版)
WECHAT_CORP_ID=
WECHAT_CORP_SECRET=
WECHAT_AGENT_ID=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=
